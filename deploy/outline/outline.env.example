# Outline 本地开发环境示例
# 使用方式：
# cp deploy/outline/outline.env.example deploy/outline/outline.env
#
# 注意：
# 1. SECRET_KEY 和 UTILS_SECRET 请用 openssl rand -hex 32 重新生成；
# 2. 本配置仅适合本地开发联调，不建议直接用于生产环境；
# 3. Outline 默认需要登录，这里使用本地 Dex OIDC。

NODE_ENV=production

URL=http://localhost:3000
PORT=3000

DATABASE_URL=postgres://outline:outlinepass@outline-postgres:5432/outline
REDIS_URL=redis://outline-redis:6379

SECRET_KEY=please_change_me_to_a_64_character_random_string_aaaaaaaa
UTILS_SECRET=please_change_me_to_another_64_character_random_string_bbbbb

FORCE_HTTPS=false
ENABLE_UPDATES=false
WEB_CONCURRENCY=1

FILE_STORAGE=s3
AWS_ACCESS_KEY_ID=outline
AWS_SECRET_ACCESS_KEY=outlinepass
AWS_REGION=us-east-1
AWS_S3_UPLOAD_BUCKET_URL=http://localhost:19000
AWS_S3_UPLOAD_BUCKET_NAME=outline
AWS_S3_UPLOAD_MAX_SIZE=26214400
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_ACL=private

OIDC_CLIENT_ID=outline
OIDC_CLIENT_SECRET=outline-secret
OIDC_AUTH_URI=http://localhost:5556/auth
OIDC_TOKEN_URI=http://outline-dex:5556/token
OIDC_USERINFO_URI=http://outline-dex:5556/userinfo
OIDC_USERNAME_CLAIM=email
OIDC_DISPLAY_NAME=OIDC
OIDC_SCOPES=openid profile email