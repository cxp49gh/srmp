# SRMP 开发环境配置文件
# 复制为 .env.dev 后修改使用

# 外部 PostgreSQL
DEV_DB_HOST=127.0.0.1
DEV_DB_PORT=5432
DEV_DB_NAME=srmp
DEV_DB_USER=srmp
DEV_DB_PASSWORD=srmp123

# 外部 Redis
DEV_REDIS_HOST=127.0.0.1
DEV_REDIS_PORT=6379

# 外部 MinIO
DEV_MINIO_ENDPOINT=http://127.0.0.1:9000
DEV_MINIO_ACCESS_KEY=minioadmin
DEV_MINIO_SECRET_KEY=minioadmin
DEV_MINIO_BUCKET=srmp

# LLM 配置（可选）
SRMP_LLM_API_KEY=your-api-key
SRMP_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SRMP_LLM_MODEL=qwen3.6-flash
SRMP_EMBEDDING_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
SRMP_EMBEDDING_MODEL=text-embedding-v4

# Outline 配置（可选）
OUTLINE_ENABLED=false
OUTLINE_BASE_URL=http://127.0.0.1:3000
OUTLINE_API_TOKEN=
OUTLINE_DEFAULT_COLLECTION_ID=
